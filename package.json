{
  "name": "skyflow-node",
  "version": "2.1.1",
  "description": "Skyflow SDK for Node.js",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "scripts": {
    "test": "jest --coverage",
    "contract-snapshot": "npm run build && npx api-extractor run --local",
    "contract-snapshot-verify": "npm run build && npx api-extractor run",
    "build": "tsc",
    "eslint": "eslint '**/*.{js,ts}' --max-warnings 0",
    "prettier": "prettier --list-different '**/*.{js,ts}'",
    "lint": "npm run eslint",
    "lint-fix": "prettier --write '**/*.{js,ts}' && eslint --fix '**/*.{js,ts}'",
    "spellcheck": "cspell '**/*.{ts,js,md}'",
    "docs-gen": "typedoc && node scripts/docs-script/markdown-gen.js && npx ts-node scripts/docs-script/processMarkdown.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skyflowapi/skyflow-node-sdk.git"
  },
  "browser": {
    "child_process": false
  },
  "author": "",
  "license": "MIT",
  "keywords": [
    "skyflow",
    "privacy",
    "api",
    "security",
    "vault",
    "PII",
    "tokenization"
  ],
  "dependencies": {
    "@babel/runtime": "7.29.2",
    "dotenv": "16.6.1",
    "form-data": "4.0.5",
    "form-data-encoder": "4.1.0",
    "formdata-node": "6.0.3",
    "js-base64": "3.7.7",
    "jsonwebtoken": "9.0.3",
    "jwt-decode": "3.1.2",
    "node-fetch": "2.7.0",
    "qs": "6.15.1",
    "readable-stream": "4.7.0",
    "url-join": "4.0.1"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "7.58.7",
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@babel/plugin-transform-object-assign": "7.27.1",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/js": "9.39.4",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "18.19.130",
    "@types/node-fetch": "2.6.13",
    "@types/qs": "6.15.1",
    "@types/readable-stream": "4.0.23",
    "@types/url-join": "4.0.1",
    "cspell": "9.8.0",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "prettier": "3.6.2",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "typescript": "5.7.3",
    "typescript-eslint": "8.59.3",
    "webpack": "5.106.2"
  }
}
